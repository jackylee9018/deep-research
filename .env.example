# Tavily (web search)
TAVILY_API_KEY="tvly-your_api_key"
# SEARCH_CONCURRENCY=2

# OpenRouter (LLM) — recommended
OPENROUTER_API_KEY="sk-or-v1-your_api_key"
OPENROUTER_MODEL="google/gemini-2.5-flash-preview"
# OPENROUTER_REFERER="https://your-site.example"
# OPENROUTER_TITLE="Open Deep Research"

# Or any OpenAI-compatible API
# OPENAI_KEY="your_api_key"
# OPENAI_ENDPOINT="https://openrouter.ai/api/v1"
# CUSTOM_MODEL="google/gemini-2.5-flash-preview"

# Optional: Fireworks DeepSeek R1 (takes priority over CUSTOM_MODEL when set)
# FIREWORKS_KEY="your_fireworks_key"

# CONTEXT_SIZE=128000
