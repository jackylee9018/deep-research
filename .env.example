# Tavily (web search)
TAVILY_API_KEY="tvly-your_api_key"
# SEARCH_CONCURRENCY=2

# OpenRouter (LLM) — recommended
OPENROUTER_API_KEY="sk-or-v1-your_api_key"
OPENROUTER_MODEL="google/gemma-4-31b-it"
# OPENROUTER_REFERER="https://your-site.example"
# OPENROUTER_TITLE="Open Deep Research"

# Or any OpenAI-compatible API
# OPENAI_KEY="your_api_key"
# OPENAI_ENDPOINT="https://openrouter.ai/api/v1"
# CUSTOM_MODEL="google/gemini-2.5-flash-preview"

# Optional: Fireworks DeepSeek R1 (takes priority over CUSTOM_MODEL when set)
# FIREWORKS_KEY="your_fireworks_key"

# CONTEXT_SIZE=128000

# Optional: Pexels API for slide photos (https://www.pexels.com/api/). Without it, picsum placeholders are used.
# PEXELS_API_KEY=

# PPT outline stream timeouts (ms). First-byte = wait for model to start; idle = gap between chunks.
# PPT_OUTLINE_STREAM_FIRST_BYTE_MS=120000
# PPT_OUTLINE_STREAM_IDLE_MS=30000

# PPT export: nodejs (PptxGenJS, default) or python (skills/pptx/generate.py)
# PPTX_EXPORT_BACKEND=nodejs
# Use PowerPoint slide layouts from templates/ (python-pptx). Set false for Node-only export.
# PPT_TEMPLATE_LAYOUTS=true
# PPTX_TEMPLATE_PATH=templates/default.pptx
# PPTX_PYTHON=python3
# Persist generated decks under a fixed directory (default: OS temp /deep-research-ppt-jobs)
# PPT_OUTPUT_DIR=/absolute/path/to/ppt-output

# Home → Open WebUI (scheme A: redirect with ?q= prompt; auto-submits in OWUI)
# Runtime (recommended — no rebuild needed when URL changes):
OPENWEBUI_URL="https://ai.spit.hk"
# Build-time fallback (optional):
# NEXT_PUBLIC_OPENWEBUI_URL="https://ai.spit.hk"
# NEXT_PUBLIC_OPENWEBUI_MODEL="your-model-id-in-openwebui"
# NEXT_PUBLIC_APP_NAME="SP Intelligence"
# NEXT_PUBLIC_USER_NAME=""
# Scheme A does not require an API key. Optional for future server-side OWUI API calls:
# OPENWEBUI_API_KEY=""
